# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW_GID=0
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres/airflow
AIRFLOW__CELERY__BROKER_URL=redis://:@redis:6379/0

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=PrukbdUBEH4oyxiP0UIU1_5-PMLJgrUqCb3HGU1skKQ=

# Core Settings
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__CORE__DEFAULT_TIMEZONE=UTC
AIRFLOW__CORE__DEFAULT_UI_TIMEZONE=UTC

# Security
AIRFLOW__API__AUTH_BACKENDS=airflow.api.auth.backend.basic_auth
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret_key_change_me

# Logging
AIRFLOW__LOGGING__LOGGING_LEVEL=INFO
AIRFLOW__LOGGING__COLORED_CONSOLE_LOG=true
AIRFLOW__LOGGING__LOG_FORMAT=[%%(asctime)s] {%%(filename)s:%%(lineno)d} %%(levelname)s - %%(message)s
AIRFLOW__LOGGING__DAG_PROCESSOR_MANAGER_LOG_LOCATION=/opt/airflow/logs/dag_processor_manager/dag_processor_manager.log

# Scheduler
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=10
AIRFLOW__SCHEDULER__DAG_DIR_LIST_INTERVAL=30
AIRFLOW__SCHEDULER__MAX_THREADS=2
AIRFLOW__SCHEDULER__CATCHUP_BY_DEFAULT=false

# Worker
AIRFLOW__CELERY__WORKER_CONCURRENCY=4
AIRFLOW__CELERY__WORKER_PREFETCH_MULTIPLIER=1
AIRFLOW__CELERY__WORKER_SEND_TASK_EVENTS=true

# Email (optional)
AIRFLOW__EMAIL__EMAIL_BACKEND=airflow.utils.email.send_email_smtp
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_STARTTLS=true
AIRFLOW__SMTP__SMTP_SSL=false
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_MAIL_FROM=airflow@example.com
AIRFLOW__SMTP__SMTP_USER=your_email@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_email_password

# AWS Configuration (for connections)
AIRFLOW_CONN_AWS_DEFAULT=aws://?conn_type=aws

# Snowflake Configuration (for connections)
# AIRFLOW_CONN_SNOWFLAKE_DEFAULT is disabled; configure snowflake_default in Airflow UI

# Custom Variables
ENVIRONMENT=dev
AWS_DEFAULT_REGION=ap-south-1
KINESIS_STREAM_NAME=sales-data-stream-dev
S3_RAW_BUCKET=sales-platform-raw-sakthi-2026-01
S3_PROCESSED_BUCKET=sales-platform-processed-sakthi-2026-01
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_WAREHOUSE=SALES_WH
SNOWFLAKE_DATABASE=SALES_DB
SNOWFLAKE_SCHEMA=RAW


